{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "types": [],
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": false, 
    
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": false,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"]
}
